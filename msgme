#!/bin/zsh

# 1. Environment & Alias Inheritance
setopt aliases
[[ -f ~/.zshrc ]] && source ~/.zshrc
[[ -f ~/.zprofile ]] && source ~/.zprofile

# 2. Load Defaults from Config
CONF_FILE="$HOME/.msgme.conf"
[[ -f "$CONF_FILE" ]] && source "$CONF_FILE"

# Set Initial Defaults (if not in config)
VERBOSITY=${VERBOSITY:-2}
AI_HOST=${AI_HOST:-"localhost:11434"}
AI_MODEL=${AI_MODEL:-""}

# Store config values for defaults (supports space-separated lists)
CONF_PHONES=(${=PHONE})
CONF_EMAILS=(${=EMAIL})
AI_EXTRA_PROMPT="${AIP:-}"

# Active delivery lists (built by arg parser)
PHONES=()
EMAILS=()
USE_SPEECH=false
HAS_PHONE_FLAG=false
HAS_EMAIL_FLAG=false
HAS_SPEECH_FLAG=false

show_help() {
    cat << EOF
Usage: msgme [options] -- command [args]

Channels (additive — use multiple to combine):
  -n  <numbers...>    Add iMessage recipients
  -nr <numbers...>    Replace config phone list
  -e  <addrs...>      Add email recipients
  -er <addrs...>      Replace config email list
  -s  [text]          Enable speech (optional custom text)

AI:
  -a  <model>         AI provider/model (auto-detected from name)
  -aip <prompt>       Add to default AI instructions
  -aipr <prompt>      Replace default AI instructions

Options:
  -m <text>           Static text message (skip AI)
  -v <1-3>            Verbosity (1: Brief, 2: Normal, 3: Chatty)
  -d                  Debug mode (foreground, shows JSON traffic)
  -h                  Show this help

Flags accept any length: -e, -em, -email all work.
Defaults: Set DEFAULT="IMESSAGE EMAIL SPEECH" in ~/.msgme.conf

Examples:
  msgme -- ./build.sh                              # DEFAULT channels + config AI
  msgme -n +15559999999 -email team@co.com -- cmd  # add recipients
  msgme -nr +15559999999 -er solo@co.com -- cmd    # replace recipients
  msgme -aip "respond in Spanish" -- ./deploy.sh   # add AI instructions
EOF
}

# Helper: consume space-separated values until next flag or --
_consume_values() {
    local -a vals=()
    while [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]]; do
        vals+=("$1"); shift
    done
    # Return values via global
    _CONSUMED=("${vals[@]}")
    _REMAINING=$#
}

# 3. Robust Argument Parser
while [[ $# -gt 0 ]]; do
    case "$1" in
        -nr*)
            HAS_PHONE_FLAG=true; PHONES=(); shift
            while [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]]; do
                PHONES+=("$1"); shift
            done
            ;;
        -n*)
            HAS_PHONE_FLAG=true; shift
            [[ "$DEFAULT" == *IMESSAGE* ]] && PHONES+=("${CONF_PHONES[@]}")
            while [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]]; do
                PHONES+=("$1"); shift
            done
            ;;
        -er*|--emailr*)
            HAS_EMAIL_FLAG=true; EMAILS=(); shift
            while [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]]; do
                EMAILS+=("$1"); shift
            done
            ;;
        -e*|--email*)
            HAS_EMAIL_FLAG=true; shift
            [[ "$DEFAULT" == *EMAIL* ]] && EMAILS+=("${CONF_EMAILS[@]}")
            while [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]]; do
                EMAILS+=("$1"); shift
            done
            ;;
        -s*)   HAS_SPEECH_FLAG=true; USE_SPEECH=true; shift
               [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]] && { STATIC_SPEECH="$1"; shift; } ;;
        -m*)   [[ -n "$2" && "$2" != -* && "$2" != "--" ]] && { STATIC_MSG="$2"; shift 2; } || shift 1 ;;
        -v*)   [[ -n "$2" && "$2" != -* && "$2" != "--" ]] && { VERBOSITY="$2"; shift 2; } || shift 1 ;;
        -aipr*)
            shift
            [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]] && { AI_EXTRA_PROMPT="$1"; shift; } ;;
        -aip*)
            shift
            if [[ $# -gt 0 && "$1" != -* && "$1" != "--" ]]; then
                [[ -n "$AI_EXTRA_PROMPT" ]] && AI_EXTRA_PROMPT="$AI_EXTRA_PROMPT $1" || AI_EXTRA_PROMPT="$1"
                shift
            fi
            ;;
        -a*)
            shift
            if [[ "$1" == *" "* ]]; then
                AI_HOST="${1%% *}"; AI_MODEL="${1#* }"; shift
            elif [[ "$1" =~ ^[a-zA-Z0-9._-]+:[0-9]+$ ]]; then
                AI_HOST="$1"; AI_MODEL="$2"; shift 2
            elif [[ "$1" == ":"* ]]; then
                AI_HOST="localhost${1}"; AI_MODEL="$2"; shift 2
            else
                AI_MODEL="$1"; shift
            fi
            ;;
        -d*)   DEBUG=1; shift ;;
        -h*)   show_help; exit 0 ;;
        --)    shift; break ;;
        *)     shift ;;
    esac
done

# Apply DEFAULT from config per-channel (only for channels without explicit flags)
if [[ -n "$DEFAULT" ]]; then
    [[ "$HAS_PHONE_FLAG" != true && "$DEFAULT" == *IMESSAGE* ]] && PHONES+=("${CONF_PHONES[@]}")
    [[ "$HAS_EMAIL_FLAG" != true && "$DEFAULT" == *EMAIL* ]] && EMAILS+=("${CONF_EMAILS[@]}")
    [[ "$HAS_SPEECH_FLAG" != true && "$DEFAULT" == *SPEECH* ]] && USE_SPEECH=true
fi

APP_CMD=("$@")
[[ ${#APP_CMD} -eq 0 ]] && { show_help; exit 0; }

# 4. Execute the Target App
LOG_FILE=$(mktemp /tmp/msgme.XXXXXX)
"${APP_CMD[@]}" 2>&1 | tee "$LOG_FILE"
EXIT_CODE=${pipestatus[1]}

# 5. The Notification Logic
notify() {
    [[ -n $DEBUG ]] && echo "\n--- DEBUG: NOTIFY START ---"
    local output_content=$(tail -n 100 "$LOG_FILE")
    local final_msg=$STATIC_MSG
    local final_speech=$STATIC_SPEECH

    # AI Processing
    if [[ -n $AI_MODEL ]]; then
        local sys_text="You are a CLI notification assistant. Analyze the output. Return ONLY a JSON object with 'sms' (string) and 'speech' (string) keys. Verbosity: $VERBOSITY. 'sms' should be a concise summary. 'speech' must be a natural sentence. Context: $AI_EXTRA_PROMPT"
        local user_text="Exit Code: $EXIT_CODE\nOutput: $output_content"
        local full_prompt="$sys_text\n\n$user_text"

        # Detect AI provider from model name
        local ai_provider="ollama"
        case "$AI_MODEL" in
            claude|claude-*) ai_provider="claude" ;;
            gemini|gemini-*) ai_provider="gemini" ;;
            gpt-*|o1-*|o3-*|o4-*|o5-*) ai_provider="codex" ;;
        esac
        [[ -n $DEBUG ]] && echo "\n--- DEBUG: AI Provider: $ai_provider | Model: $AI_MODEL ---"

        local response
        local ai_cmd_file=$(mktemp /tmp/msgme_ai.XXXXXX)

        case "$ai_provider" in
            claude)
                local claude_cmd="echo $(printf '%q' "$full_prompt") | claude -p 'Return ONLY a JSON object with sms and speech keys. sms: concise summary. speech: natural sentence.' --model $AI_MODEL --output-format json 2>&1"
                [[ -n $DEBUG ]] && echo "\n--- DEBUG: AI REQUEST ---\nProvider: claude CLI\nModel: $AI_MODEL"
                if [[ -n $DEBUG ]]; then
                    printf "\n⏳ Waiting for AI (%s)..." "$AI_MODEL"
                    echo "$full_prompt" | claude -p "$sys_text" --model "$AI_MODEL" --output-format json > "$ai_cmd_file" 2>&1 &
                    local ai_pid=$!
                    while kill -0 $ai_pid 2>/dev/null; do printf "."; sleep 1; done
                    response=$(<"$ai_cmd_file")
                    echo " done!"
                else
                    response=$(echo "$full_prompt" | claude -p "$sys_text" --model "$AI_MODEL" --output-format json 2>&1)
                fi
                ;;
            gemini)
                [[ -n $DEBUG ]] && echo "\n--- DEBUG: AI REQUEST ---\nProvider: gemini CLI\nModel: $AI_MODEL"
                if [[ -n $DEBUG ]]; then
                    printf "\n⏳ Waiting for AI (%s)..." "$AI_MODEL"
                    gemini -p "$sys_text $user_text" -o json > "$ai_cmd_file" 2>/dev/null &
                    local ai_pid=$!
                    while kill -0 $ai_pid 2>/dev/null; do printf "."; sleep 1; done
                    response=$(<"$ai_cmd_file")
                    echo " done!"
                else
                    response=$(gemini -p "$sys_text $user_text" -o json 2>/dev/null)
                fi
                ;;
            codex)
                [[ -n $DEBUG ]] && echo "\n--- DEBUG: AI REQUEST ---\nProvider: codex CLI\nModel: $AI_MODEL"
                if [[ -n $DEBUG ]]; then
                    printf "\n⏳ Waiting for AI (%s)..." "$AI_MODEL"
                    codex exec -m "$AI_MODEL" --skip-git-repo-check --ephemeral "$sys_text $user_text" > "$ai_cmd_file" 2>&1 &
                    local ai_pid=$!
                    while kill -0 $ai_pid 2>/dev/null; do printf "."; sleep 1; done
                    response=$(<"$ai_cmd_file")
                    echo " done!"
                else
                    response=$(codex exec -m "$AI_MODEL" --skip-git-repo-check --ephemeral "$sys_text $user_text" 2>&1)
                fi
                ;;
            ollama)
                local payload=$(python3 -c '
import json, sys
data = {"model": sys.argv[3], "messages": [{"role": "system", "content": sys.argv[1]}, {"role": "user", "content": sys.argv[2]}], "stream": False, "format": "json"}
print(json.dumps(data))' "$sys_text" "$user_text" "$AI_MODEL")
                [[ -n $DEBUG ]] && echo "\n--- DEBUG: AI REQUEST ---" && echo "$payload" | python3 -m json.tool
                if [[ -n $DEBUG ]]; then
                    printf "\n⏳ Waiting for AI (%s)..." "$AI_MODEL"
                    curl -s --max-time 120 -X POST "http://$AI_HOST/api/chat" -H "Content-Type: application/json" -d "$payload" > "$ai_cmd_file" &
                    local ai_pid=$!
                    while kill -0 $ai_pid 2>/dev/null; do printf "."; sleep 1; done
                    response=$(<"$ai_cmd_file")
                    echo " done!"
                else
                    response=$(curl -s --max-time 120 -X POST "http://$AI_HOST/api/chat" -H "Content-Type: application/json" -d "$payload")
                fi
                ;;
        esac
        rm -f "$ai_cmd_file"
        if [[ -n $DEBUG ]]; then
            echo "\n--- DEBUG: AI RESPONSE ---"
            printf '%s\n' "$response" | python3 -m json.tool 2>/dev/null || printf '%s\n' "$response"
        fi

        # Universal JSON extraction — handles all provider response formats
        local results=$(printf '%s' "$response" | python3 -c "
import sys, json, re

def extract_json_obj(text):
    '''Find first JSON object with sms/speech keys in any text'''
    # Strip markdown code fences
    text = re.sub(r'\`\`\`json?\s*', '', text)
    text = re.sub(r'\`\`\`', '', text)
    text = text.strip()
    try:
        obj = json.loads(text)
        if isinstance(obj, dict) and ('sms' in obj or 'speech' in obj):
            return obj
    except: pass
    # Try to find embedded JSON
    for match in re.finditer(r'\{[^{}]*\}', text):
        try:
            obj = json.loads(match.group())
            if 'sms' in obj or 'speech' in obj:
                return obj
        except: pass
    return {}

raw = sys.stdin.read().strip()
try:
    data = json.loads(raw)
    # Claude CLI format
    if 'result' in data:
        content = data['result']
    # Gemini CLI format
    elif 'response' in data:
        content = data['response']
    # Ollama format
    elif 'message' in data and 'content' in data.get('message', {}):
        content = data['message']['content']
    # OpenAI format
    elif 'choices' in data:
        content = data['choices'][0]['message']['content']
    # Gemini format
    elif 'candidates' in data:
        content = data['candidates'][0]['content']['parts'][0]['text']
    else:
        content = raw
except:
    content = raw

result = extract_json_obj(str(content))
sms = result.get('sms', '')
speech = result.get('speech', '')
if isinstance(sms, list):
    sms = ', '.join([str(i) for i in sms])
print(json.dumps({'sms': str(sms), 'speech': str(speech)}))
")
        final_msg=$(printf '%s' "$results" | python3 -c "import sys, json; print(json.loads(sys.stdin.read()).get('sms', ''))")
        final_speech=$(printf '%s' "$results" | python3 -c "import sys, json; print(json.loads(sys.stdin.read()).get('speech', ''))")
    fi

    # Fallbacks - Only trigger if the variables are completely empty
    final_msg="${final_msg:-${STATIC_MSG:-"App done (Code $EXIT_CODE)"}}"

    # 6. Deliver iMessage to all recipients
    for phone in "${PHONES[@]}"; do
        [[ -z "$phone" ]] && continue
        [[ -n "$DEBUG" ]] && echo "Sending iMessage to $phone: $final_msg"
        local imsg_err
        imsg_err=$(osascript -e 'on run argv' \
                  -e 'tell application "Messages"' \
                  -e 'set targetService to 1st account whose service type = iMessage' \
                  -e 'set targetBuddy to participant (item 2 of argv) of targetService' \
                  -e 'send (item 1 of argv) to targetBuddy' \
                  -e 'end tell' \
                  -e 'end run' -- "$final_msg" "$phone" 2>&1)
        if [[ -n "$DEBUG" && -n "$imsg_err" ]]; then
            echo "--- DEBUG: iMessage result ---\n$imsg_err"
        fi
    done

    # 7. Deliver Email to all recipients
    local email_from="${EMAIL_FROM:-"msgme@localhost"}"
    local email_from_name="${EMAIL_FROM_NAME:-"msgme"}"
    for email_addr in "${EMAILS[@]}"; do
        [[ -z "$email_addr" ]] && continue
        [[ -n "$DEBUG" ]] && echo "Sending email to $email_addr: $final_msg"
        local email_response

        if [[ -n "$BREVO_SMTP_API_KEY" ]]; then
            [[ -n "$DEBUG" ]] && echo "--- DEBUG: Email method: Brevo REST API ---"
            email_response=$(curl -4 -s --max-time 15 -X POST 'https://api.brevo.com/v3/smtp/email' \
                -H "api-key: $BREVO_SMTP_API_KEY" \
                -H 'Content-Type: application/json' \
                -d "$(python3 -c '
import json, sys
print(json.dumps({
    "sender": {"name": sys.argv[1], "email": sys.argv[2]},
    "to": [{"email": sys.argv[3]}],
    "subject": "msgme notification",
    "textContent": sys.argv[4]
}))' "$email_from_name" "$email_from" "$email_addr" "$final_msg")" 2>&1)
        else
            local smtp_host="${SMTP_HOST:-smtp.gmail.com}"
            local smtp_port="${SMTP_PORT:-587}"
            local smtp_user="${SMTP_USER:-$BREVO_SMTP_USERNAME}"
            local smtp_pass="${SMTP_PASS:-$BREVO_SMTP_KEY}"
            [[ -n "$DEBUG" ]] && echo "--- DEBUG: Email method: SMTP ($smtp_host:$smtp_port) ---"
            email_response=$(python3 -c "
import smtplib, sys, os
from email.mime.text import MIMEText
msg = MIMEText(sys.argv[4])
msg['Subject'] = 'msgme notification'
msg['From'] = sys.argv[2]
msg['To'] = sys.argv[3]
smtp = smtplib.SMTP(sys.argv[5], int(sys.argv[6]))
smtp.starttls()
smtp.login(sys.argv[7], sys.argv[8])
smtp.send_message(msg)
smtp.quit()
print('Sent!')
" "$email_from_name" "$email_from" "$email_addr" "$final_msg" "$smtp_host" "$smtp_port" "$smtp_user" "$smtp_pass" 2>&1)
        fi
        if [[ -n "$DEBUG" ]]; then
            echo "--- DEBUG: Email result ---\n$email_response"
        fi
    done

    # 8. Deliver Speech
    if [[ "$USE_SPEECH" == true ]]; then
        final_speech="${final_speech:-${STATIC_SPEECH:-"Application completed"}}"
        [[ -n "$DEBUG" ]] && echo "Speaking: $final_speech"
        say "$final_speech"
    fi

    rm "$LOG_FILE"
}

# 8. Backgrounding Control
if [[ -n $DEBUG ]]; then
    notify
else
    notify &!
fi